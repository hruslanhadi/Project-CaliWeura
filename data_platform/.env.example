# ===================================================
# ENVIRONMENT TEMPLATE - COPY TO .env.development OR .env.production
# ===================================================
# IMPORTANT: NEVER COMMIT ACTUAL .env FILES
# Use this template and create environment-specific files
# Add to .gitignore: .env.* (except .env.example)

# ===================================================
# Airflow Configuration
# ===================================================
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW__CORE__LOAD_EXAMPLES=False

# IMPORTANT: Use environment-specific executor
# Development: LocalExecutor (single machine)
# Production: CeleryExecutor (distributed)
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Security: Generate a strong secret key
# Production: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_to_secure_random_key_32_chars

# RBAC and security
AIRFLOW__WEBSERVER__RBAC=True
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=False
AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS=False

# ===================================================
# PostgreSQL Configuration
# ===================================================
POSTGRES_USER=airflow_meta
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=airflow

# Database connection string (used by Airflow)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow_meta:CHANGE_ME_SECURE_PASSWORD@postgres:5432/airflow

# ===================================================
# PostgreSQL Warehouse (separate from Airflow metadata)
# ===================================================
PG_WAREHOUSE_HOST=postgres
PG_WAREHOUSE_USER=warehouse_user
PG_WAREHOUSE_PASSWORD=CHANGE_ME_SECURE_PASSWORD
PG_WAREHOUSE_PORT=5432
PG_WAREHOUSE_DB=data_warehouse

# Analytics user (read-only)
PG_ANALYTICS_USER=analytics_user
PG_ANALYTICS_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ===================================================
# MinIO / S3 Configuration
# ===================================================
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_SECURE_PASSWORD
MINIO_USE_SSL=false

# AWS CLI compatibility
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_SECURE_PASSWORD
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_BRONZE=bronze
S3_BUCKET_SILVER=silver
S3_BUCKET_GOLD=gold

# ===================================================
# Spark Configuration (DEVELOPMENT)
# ===================================================
# For 16GB laptop: minimal resources
SPARK_MASTER=spark://spark_master:7077
SPARK_DRIVER_MEMORY=512m
SPARK_EXECUTOR_MEMORY=512m
SPARK_EXECUTOR_CORES=1
SPARK_EXECUTOR_INSTANCES=1

# ===================================================
# Spark Configuration (PRODUCTION - override in docker-compose.prod.yml)
# ===================================================
# For high-performance clusters:
# SPARK_DRIVER_MEMORY=4g
# SPARK_EXECUTOR_MEMORY=4g
# SPARK_EXECUTOR_CORES=4
# SPARK_EXECUTOR_INSTANCES=4

# ===================================================
# Kafka Configuration
# ===================================================
KAFKA_BROKERS=kafka:9092
KAFKA_CONSUMER_GROUP=data_platform
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ===================================================
# Redis Configuration (for CeleryExecutor in production)
# ===================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow_meta:CHANGE_ME_SECURE_PASSWORD@postgres:5432/airflow

# ===================================================
# Logging Configuration
# ===================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Development: simple logging
# LOGGING_HANDLER=default

# Production: structured JSON logging
# LOGGING_HANDLER=json

# ===================================================
# Application Settings
# ===================================================
ENVIRONMENT=development
DEBUG=True
TIMEZONE=UTC
MAX_ACTIVE_RUNS_PER_DAG=1
PARALLELISM=4

# ===================================================
# Monitoring & Observability (Production)
# ===================================================
ENABLE_PROMETHEUS=False
PROMETHEUS_PORT=9090
ENABLE_GRAFANA=False
GRAFANA_PORT=3000
ENABLE_LOKI=False
LOKI_PORT=3100

# ===================================================
# Data Quality & Validation
# ===================================================
DATA_QUALITY_CHECKS=True
DATA_PROFILING_ENABLED=False
