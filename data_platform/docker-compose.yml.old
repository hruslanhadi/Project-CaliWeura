version: '3.8'

services:
  # ============================================================================
  # PostgreSQL - Data Warehouse
  # ============================================================================
  postgres:
    image: postgres:15-alpine
    container_name: caliweura_postgres
    environment:
      POSTGRES_USER: airflow
      POSTGRES_PASSWORD: airflow_secure_pass
      POSTGRES_DB: airflow
      POSTGRES_INITDB_ARGS: "-c max_connections=100"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./scripts/init_db.sql:/docker-entrypoint-initdb.d/01-init.sql
    ports:
      - "5432:5432"
    networks:
      - data_platform_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U airflow"]
      interval: 10s
      timeout: 5s
      retries: 5
    mem_limit: 1g
    cpus: 1

  # ============================================================================
  # Redis - Celery Backend & Caching
  # ============================================================================
  redis:
    image: redis:7-alpine
    container_name: caliweura_redis
    command: redis-server --maxmemory 512mb --maxmemory-policy allkeys-lru
    ports:
      - "6379:6379"
    networks:
      - data_platform_network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    mem_limit: 512m

  # ============================================================================
  # Airflow Webserver
  # ============================================================================
  airflow_webserver:
    build:
      context: ./docker
      dockerfile: Dockerfile.airflow
    container_name: caliweura_airflow_webserver
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      AIRFLOW__CORE__DAGS_FOLDER: /opt/airflow/dags
      AIRFLOW__CORE__LOAD_EXAMPLES: 'False'
      AIRFLOW__CORE__EXECUTOR: CeleryExecutor
      AIRFLOW__CELERY__BROKER_URL: redis://redis:6379/0
      AIRFLOW__CELERY__RESULT_BACKEND: db+postgresql://airflow:airflow_secure_pass@postgres:5432/airflow
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql://airflow:airflow_secure_pass@postgres:5432/airflow
      AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS: 'False'
      AIRFLOW__CORE__LOAD_DEFAULT_VARIABLES: 'False'
      AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION: 'True'
      AIRFLOW__CORE__DAG_FILE_PROCESSOR_TIMEOUT: 60
      AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG: 3
      AIRFLOW__CORE__PARALLELISM: 4
    volumes:
      - ./dags:/opt/airflow/dags
      - ./spark_jobs:/opt/airflow/spark_jobs
      - ./scripts:/opt/airflow/scripts
      - ./configs:/opt/airflow/configs
      - airflow_logs:/opt/airflow/logs
    ports:
      - "8080:8080"
    networks:
      - data_platform_network
    command: >
      sh -c "airflow db upgrade &&
             airflow users create --username admin --firstname Admin --lastname User --role Admin --email admin@airflow.local --password admin123 || true &&
             airflow webserver"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    mem_limit: 2g
    cpus: 2

  # ============================================================================
  # Airflow Scheduler
  # ============================================================================
  airflow_scheduler:
    build:
      context: ./docker
      dockerfile: Dockerfile.airflow
    container_name: caliweura_airflow_scheduler
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      airflow_webserver:
        condition: service_healthy
    environment:
      AIRFLOW__CORE__DAGS_FOLDER: /opt/airflow/dags
      #AIRFLOW__CORE__EXECUTOR: CeleryExecutor
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__CELERY__BROKER_URL: redis://redis:6379/0
      AIRFLOW__CELERY__RESULT_BACKEND: db+postgresql://airflow:airflow_secure_pass@postgres:5432/airflow
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql://airflow:airflow_secure_pass@postgres:5432/airflow
      AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS: 'False'
      AIRFLOW__CORE__LOAD_DEFAULT_VARIABLES: 'False'
      AIRFLOW__CORE__DAG_FILE_PROCESSOR_TIMEOUT: 60
      AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG: 3
      AIRFLOW__CORE__PARALLELISM: 4
    volumes:
      - ./dags:/opt/airflow/dags
      - ./spark_jobs:/opt/airflow/spark_jobs
      - ./scripts:/opt/airflow/scripts
      - ./configs:/opt/airflow/configs
      - airflow_logs:/opt/airflow/logs
    networks:
      - data_platform_network
    command: airflow scheduler
    mem_limit: 1g
    cpus: 1

  # ============================================================================
  # Airflow Worker (Celery)
  # If you have enough resources, you can uncomment this section to enable distributed task execution with Celery workers. Make sure to adjust the number of workers and their resource limits based on your system's capabilities.
  # ============================================================================
  # airflow_worker:
  #   build:
  #     context: ./docker
  #     dockerfile: Dockerfile.airflow
  #   container_name: caliweura_airflow_worker
  #   depends_on:
  #     postgres:
  #       condition: service_healthy
  #     redis:
  #       condition: service_healthy
  #   environment:
  #     AIRFLOW__CORE__DAGS_FOLDER: /opt/airflow/dags
  #     AIRFLOW__CORE__EXECUTOR: CeleryExecutor
  #     AIRFLOW__CELERY__BROKER_URL: redis://redis:6379/0
  #     AIRFLOW__CELERY__RESULT_BACKEND: db+postgresql://airflow:airflow_secure_pass@postgres:5432/airflow
  #     AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql://airflow:airflow_secure_pass@postgres:5432/airflow
  #     AIRFLOW__LOGGING__LOGGING_LEVEL: INFO
  #   volumes:
  #     - ./dags:/opt/airflow/dags
  #     - ./spark_jobs:/opt/airflow/spark_jobs
  #     - ./scripts:/opt/airflow/scripts
  #     - ./configs:/opt/airflow/configs
  #     - airflow_logs:/opt/airflow/logs
  #   networks:
  #     - data_platform_network
  #   command: airflow celery worker --concurrency=2
  #   mem_limit: 2g
  #   cpus: 2

  # ============================================================================
  # Apache Spark - Master Node
  # ============================================================================
  spark_master:
    image: spark/spark:3.4.1
    container_name: caliweura_spark_master
    environment:
      SPARK_MODE: master
      SPARK_RPC_AUTHENTICATION_ENABLED: 'no'
      SPARK_RPC_ENCRYPTION_ENABLED: 'no'
      SPARK_LOCAL_STORAGE_ENCRYPTION_ENABLED: 'no'
      SPARK_SSL_ENABLED: 'no'
      SPARK_DRIVER_MEMORY: 1g
      SPARK_EXECUTOR_MEMORY: 1g
    ports:
      - "8081:8080"
      - "7077:7077"
      - "6066:6066"
    volumes:
      - ./spark_jobs:/opt/spark/jobs
      - spark_logs:/opt/spark/logs
    networks:
      - data_platform_network
    mem_limit: 2g
    cpus: 1.5

  # ============================================================================
  # Apache Spark - Worker Node
  # ============================================================================
  spark_worker:
    image: spark/spark:3.4-debian-11
    container_name: caliweura_spark_worker
    depends_on:
      - spark_master
    environment:
      SPARK_MODE: worker
      SPARK_MASTER_URL: spark://spark_master:7077
      SPARK_WORKER_MEMORY: 1g
      SPARK_WORKER_CORES: 1
      SPARK_RPC_AUTHENTICATION_ENABLED: 'no'
      SPARK_RPC_ENCRYPTION_ENABLED: 'no'
      SPARK_LOCAL_STORAGE_ENCRYPTION_ENABLED: 'no'
      SPARK_SSL_ENABLED: 'no'
    ports:
      - "8082:8080"
    volumes:
      - ./spark_jobs:/opt/spark/jobs
      - spark_logs:/opt/spark/logs
    networks:
      - data_platform_network
    mem_limit: 1.5g
    cpus: 1

  # ============================================================================
  # MinIO - S3-Compatible Data Lake
  # ============================================================================
  minio:
    image: minio/minio:latest
    container_name: caliweura_minio
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin_secure_pass
    command: server /data --console-address ":9001"
    volumes:
      - minio_data:/data
    ports:
      - "9000:9000"
      - "9001:9001"
    networks:
      - data_platform_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3
    mem_limit: 1g
    cpus: 1

  # ============================================================================
  # Zookeeper - Kafka Coordination
  # ============================================================================
  zookeeper:
    image: confluentinc/cp-zookeeper:7.5.0
    container_name: caliweura_zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_SYNC_LIMIT: 2
      ZOOKEEPER_INIT_LIMIT: 5
    ports:
      - "2181:2181"
    networks:
      - data_platform_network
    mem_limit: 512m
    cpus: 0.5

  # ============================================================================
  # Apache Kafka - Streaming Platform
  # ============================================================================
  kafka:
    image: confluentinc/cp-kafka:7.5.0
    container_name: caliweura_kafka
    depends_on:
      - zookeeper
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:29092,PLAINTEXT_HOST://kafka:9092
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: 'true'
      KAFKA_LOG_RETENTION_HOURS: 24
      KAFKA_LOG_SEGMENT_BYTES: 1073741824
    ports:
      - "9092:9092"
    volumes:
      - kafka_data:/var/lib/kafka/data
    networks:
      - data_platform_network
    mem_limit: 1g
    cpus: 1

volumes:
  postgres_data:
  airflow_logs:
  spark_logs:
  minio_data:
  kafka_data:

networks:
  data_platform_network:
    driver: bridge
